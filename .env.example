# Copy to .env and fill in — never commit real values

# Required for real trading
HELIUS_API_KEY=
WALLET_PRIVATE_KEY=

# Set true to actually trade on-chain
REAL_TRADING=false

# Start halted (set true on Railway so it never auto-trades after a redeploy)
START_HALTED=true

# Position size in SOL (default 0.2)
POSITION_SOL=0.2

# LaserStream endpoint (Helius)
LASER_ENDPOINT=https://laserstream-mainnet-ewr.helius-rpc.com

# Port (Railway sets this automatically)
PORT=2500
